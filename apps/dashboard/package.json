{
	"name": "@diffkit/dashboard",
	"private": true,
	"type": "module",
	"imports": {
		"#/*": "./src/*"
	},
	"scripts": {
		"predev": "node ../../scripts/link-worktree-dev-vars.mjs",
		"dev": "vite dev --port 3000",
		"build": "vite build",
		"preview": "vite preview",
		"test": "vitest run",
		"format": "biome format",
		"lint": "biome lint",
		"check": "biome check",
		"check-types": "tsc --noEmit",
		"migrate": "pnpm run migrate:local",
		"migrate:local": "node ../../scripts/run-d1-migrations.mjs DB --local",
		"migrate:remote": "node ../../scripts/run-d1-migrations.mjs DB --remote",
		"deploy": "pnpm run build && wrangler deploy"
	},
	"dependencies": {
		"@cloudflare/vite-plugin": "^1.26.0",
		"@pierre/diffs": "^1.1.12",
		"@diffkit/icons": "workspace:*",
		"@diffkit/ui": "workspace:*",
		"@tailwindcss/vite": "^4.1.18",
		"@tanstack/react-devtools": "latest",
		"@tanstack/react-query": "latest",
		"@tanstack/react-router": "latest",
		"@tanstack/react-router-devtools": "latest",
		"@tanstack/react-router-ssr-query": "latest",
		"@tanstack/react-start": "latest",
		"@tanstack/router-plugin": "^1.132.0",
		"agentation": "^3.0.2",
		"better-auth": "^1.6.0",
		"drizzle-orm": "^0.45.2",
		"next-themes": "^0.4.6",
		"octokit": "^5.0.5",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"tailwindcss": "^4.1.18"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.5",
		"@cloudflare/workers-types": "^4.20260405.1",
		"@diffkit/typescript-config": "workspace:*",
		"@tanstack/devtools-vite": "latest",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.0",
		"@types/node": "^22.10.2",
		"@types/react": "^19.2.0",
		"@types/react-dom": "^19.2.0",
		"@vitejs/plugin-react": "^5.1.4",
		"drizzle-kit": "^0.31.10",
		"jsdom": "^28.1.0",
		"typescript": "^5.7.2",
		"vite": "^7.3.1",
		"vite-tsconfig-paths": "^5.1.4",
		"vitest": "^3.0.5",
		"wrangler": "^4.70.0"
	}
}
